<UserControl
    x:Class="Ganymede.Wpf.Playground.TestView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Ganymede.Playground.ViewModels;assembly=Ganymede.Playground"
    d:DataContext="{d:DesignInstance Type=vm:TestViewModel}"
    mc:Ignorable="d">
    <DockPanel>
        <ComboBox
            Width="500"
            Margin="5"
            DisplayMemberPath="Name"
            DockPanel.Dock="Top"
            ItemsSource="{Binding DialogServices, Mode=OneWay}"
            SelectedValue="{Binding DialogService}"
            SelectedValuePath="Value" />
        <ItemsControl
            Margin="5"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ItemsSource="{Binding DemoInteractions}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button
                        Margin="5"
                        HorizontalAlignment="Stretch"
                        Command="{Binding Command, Mode=OneWay}"
                        Content="{Binding Text, Mode=OneWay}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</UserControl>
