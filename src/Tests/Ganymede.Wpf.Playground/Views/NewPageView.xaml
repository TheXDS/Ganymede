<UserControl
    x:Class="Ganymede.Wpf.Playground.Views.NewPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Ganymede.Wpf.Playground.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:st="clr-namespace:Ganymede.Wpf.Playground.Resources.Strings.Views"
    xmlns:viewmodels="clr-namespace:Ganymede.Playground.ViewModels;assembly=Ganymede.Playground"
    d:DataContext="{d:DesignInstance viewmodels:NewPageViewModel,
                                     IsDesignTimeCreatable=True}"
    mc:Ignorable="d">
    <StackPanel Margin="50" VerticalAlignment="Center">
        <Viewbox Height="48" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="{x:Static st:NewPageView.Title}" />
        </Viewbox>
        <Separator Margin="0,10"/>
        <UniformGrid Rows="1" Grid.Row="1">
            <TextBlock
                Margin="10"
                Text="{Binding Generation, StringFormat={x:Static st:NewPageView.PageText}}"
                TextAlignment="Center"
                TextWrapping="Wrap" />
            <TextBlock
                Margin="10"
                Text="{Binding NavigationService.NavigationSetCount, StringFormat={x:Static st:NewPageView.NavStackCount}}"
                TextAlignment="Center"
                TextWrapping="Wrap" />
        </UniformGrid>
        <CheckBox Content="{x:Static st:NewPageView.AllowBack}" IsChecked="{Binding AllowBack}" Margin="15"/>
        <CheckBox Content="{x:Static st:NewPageView.AllowForward}" IsChecked="{Binding AllowForward}" Margin="15"/>
        <UniformGrid
            Grid.Row="2"
            Margin="10"
            Columns="2">
            <Button
                Margin="5"
                Padding="10,5"
                Command="{Binding SpawnNewCommand, Mode=OneWay}"
                Content="{x:Static st:NewPageView.GoFwd}" />
            <Button
                Margin="5"
                Padding="10,5"
                Command="{Binding NavigationService.NavigateBackCommand, Mode=OneWay}"
                Content="{x:Static st:NewPageView.GoBack}" />
        </UniformGrid>
    </StackPanel>
</UserControl>
