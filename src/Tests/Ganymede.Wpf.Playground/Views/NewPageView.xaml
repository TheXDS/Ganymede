<UserControl
    x:Class="Ganymede.Wpf.Playground.Views.NewPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Ganymede.Wpf.Playground.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:st="clr-namespace:Ganymede.Wpf.Playground.Resources.Strings.Views"
    xmlns:viewmodels="clr-namespace:Ganymede.Playground.ViewModels;assembly=Ganymede.Playground"
    d:DataContext="{d:DesignInstance viewmodels:NewPageViewModel,
                                     IsDesignTimeCreatable=True}"
    mc:Ignorable="d">
    <Grid Margin="50">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Viewbox HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="{x:Static st:NewPageView.Title}" />
        </Viewbox>
        <TextBlock
            Grid.Row="1"
            Margin="10"
            Text="{Binding Generation, StringFormat={x:Static st:NewPageView.PageText}}"
            TextAlignment="Center"
            TextWrapping="Wrap" />
        <UniformGrid
            Grid.Row="2"
            Margin="10"
            Columns="2">
            <Button
                Margin="5"
                Padding="10,5"
                Command="{Binding SpawnNewCommand, Mode=OneWay}"
                Content="{x:Static st:NewPageView.GoFwd}" />
            <Button
                Margin="5"
                Padding="10,5"
                Command="{Binding GoBackCommand, Mode=OneWay}"
                Content="{x:Static st:NewPageView.GoBack}" />
        </UniformGrid>
    </Grid>
</UserControl>
