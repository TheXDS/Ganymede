<UserControl
    x:Class="Ganymede.Wpf.Playground.Views.WelcomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Ganymede.Wpf.Playground.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:st="clr-namespace:Ganymede.Wpf.Playground.Resources.Strings.Views"
    xmlns:viewmodels="clr-namespace:Ganymede.Playground.ViewModels;assembly=Ganymede.Playground"
    d:DataContext="{d:DesignInstance viewmodels:WelcomeViewModel}"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Margin="15" Background="#b0000000">
            <DockPanel Margin="10">
                <TextBlock
                    DockPanel.Dock="top"
                    FontSize="36"
                    Text="{x:Static st:WelcomeView.Title}" />
                <ScrollViewer Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{x:Static st:WelcomeView.HelpText}" TextWrapping="Wrap" />
                </ScrollViewer>
            </DockPanel>
        </Border>
        <Border
            Grid.Column="1"
            Margin="15"
            Background="#b0000000">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="5">
                    <Button
                        Margin="5"
                        Command="{Binding TestNavigationCommand, Mode=OneWay}"
                        Content="{x:Static st:WelcomeView.NavToNewPage}" />
                    <Button
                        Margin="5"
                        Command="{Binding TestBusyCommand, Mode=OneWay}"
                        Content="{x:Static st:WelcomeView.TestBusy}" />
                    <Button
                        Margin="5"
                        Command="{Binding TryDialogDemoCommand, Mode=OneWay}"
                        Content="{x:Static st:WelcomeView.DialogsDemo}" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
