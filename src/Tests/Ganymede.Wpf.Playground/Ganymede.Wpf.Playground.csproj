<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net8.0-windows10.0.19041</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<UseWPF>true</UseWPF>
		<IsPackable>false</IsPackable>
		<EnableWindowsTargeting>true</EnableWindowsTargeting>
	</PropertyGroup>

	<ItemGroup>
	  <ProjectReference Include="..\..\Platform\Wpf\Ganymede.Wpf\Ganymede.Wpf.csproj" />
	  <ProjectReference Include="..\Ganymede.Playground\Ganymede.Playground.csproj" />
	</ItemGroup>

	<ItemGroup>
	  <Compile Update="Resources\Strings\Views\NewPageView.Designer.cs">
	    <DesignTime>True</DesignTime>
	    <AutoGen>True</AutoGen>
	    <DependentUpon>NewPageView.resx</DependentUpon>
	  </Compile>
	  <Compile Update="Resources\Strings\Views\WelcomeView.Designer.cs">
	    <DesignTime>True</DesignTime>
	    <AutoGen>True</AutoGen>
	    <DependentUpon>WelcomeView.resx</DependentUpon>
	  </Compile>
	</ItemGroup>

	<ItemGroup>
	  <EmbeddedResource Update="Resources\Strings\Views\NewPageView.resx">
	    <Generator>PublicResXFileCodeGenerator</Generator>
	    <LastGenOutput>NewPageView.Designer.cs</LastGenOutput>
	  </EmbeddedResource>
	  <EmbeddedResource Update="Resources\Strings\Views\WelcomeView.resx">
	    <Generator>PublicResXFileCodeGenerator</Generator>
	    <LastGenOutput>WelcomeView.Designer.cs</LastGenOutput>
	  </EmbeddedResource>
	</ItemGroup>

</Project>
