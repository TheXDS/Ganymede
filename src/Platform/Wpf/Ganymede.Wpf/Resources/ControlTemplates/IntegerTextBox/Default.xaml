<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:TheXDS.Ganymede.Controls">
    <Style TargetType="{x:Type controls:Int8TextBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Int8TextBox}">
                    <DockPanel>
                        <UniformGrid
                            Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                            Columns="1"
                            DockPanel.Dock="Right"
                            Rows="2"
                            Visibility="{TemplateBinding UpDownButtonsVisibility}">
                            <RepeatButton
                                x:Name="PART_increase"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderBrush="{x:Null}"
                                BorderThickness="0">
                                <Path Data="M 0 3 L 6 3 L 3 0 Z" Fill="Black" />
                            </RepeatButton>
                            <RepeatButton
                                x:Name="PART_decrease"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderBrush="{x:Null}"
                                BorderThickness="0">
                                <Path Data="M 0 0 L 3 3 L 6 0 Z" Fill="Black" />
                            </RepeatButton>
                        </UniformGrid>
                        <controls:TextBoxEx
                            x:Name="PART_input"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                            Focusable="True"
                            Icon="{TemplateBinding Icon}"
                            IsTabStop="True"
                            Label="{TemplateBinding Label}"
                            TabIndex="1" />
                    </DockPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
